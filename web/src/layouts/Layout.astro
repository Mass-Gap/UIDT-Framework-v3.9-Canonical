---
import '../styles/academic.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="UIDT Elite Scientific Portal — Vacuum Information Density" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | UIDT Framework</title>
    <!-- KaTeX for high-performance math rendering -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFas9aVVUs" crossorigin="anonymous">
	</head>
	<body>
    <header>
      <nav class="site-nav">
        <div class="logo">UIDT // V3.9</div>
        <a href="/UIDT-Framework-v3.9-Canonical/" class="nav-link">Compute Portal</a>
        <a href="/UIDT-Framework-v3.9-Canonical/claims" class="nav-link">Claims Ledger</a>
        <a href="/UIDT-Framework-v3.9-Canonical/geometry" class="nav-link">Geometry Manifold</a>
        <a href="https://github.com/Mass-Gap/UIDT-Framework-v3.9-Canonical" class="nav-link">GitHub Repository</a>
      </nav>
    </header>
		<slot />
    <footer>
      <p>DOI: 10.5281/zenodo.17835200 | Scientific Authority: P. Rietz</p>
      <div class="sigstore-status">SLSA Level 3 Certified // Integrity Verified</div>
    </footer>
	</body>
</html>

<style is:global>
  header {
    border-bottom: 1px solid #333;
    padding-bottom: 1rem;
    margin-bottom: 2rem;
  }
  nav.site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }
  .logo {
    font-family: var(--font-mono);
    font-weight: 800;
    color: var(--stratum-3);
    margin-right: auto; /* pushes links to the right */
  }
  .nav-link {
    color: var(--text-primary);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-transform: uppercase;
  }
  .nav-link:hover {
    color: var(--stratum-3);
  }
  footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid #333;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    display: flex;
    justify-content: space-between;
    color: var(--text-secondary);
  }
</style>
