---
import Layout from '../layouts/Layout.astro';
import TruthVerifier from '../components/TruthVerifier.jsx';
---

<Layout title="Scientific Dashboard">
	<main>
    <section class="hero">
      <span class="label">Project Objective</span>
      <h1>Vacuum Information Density as the Fundamental Geometric Scalar</h1>
      <p class="description">
        Theoretical framework proving the mass gap in pure Yang-Mills theory using the Banach fixed-point theorem and information-density scaling. 
        Category A verified results with residuals <span class="math">&epsilon; < 10^{-14}</span>.
      </p>
    </section>

    <div class="data-grid">
      <div class="data-card">
        <span class="pill pill-a">Category A</span>
        <span class="label">Spectral Gap (&Delta;*)</span>
        <div class="value">1.710 ± 0.015 GeV</div>
        <div class="verified-badge">Provenance Verified</div>
      </div>
      <div class="data-card">
        <span class="pill pill-a">Category A</span>
        <span class="label">RG Constraint (5&kappa;² = 3&lambda;_S)</span>
        <div class="value">Verified (Residual 0)</div>
        <div class="verified-badge">SLSA Signed</div>
      </div>
      <div class="data-card">
        <span class="pill pill-c">Category C</span>
        <span class="label">Universal Scaling (&gamma;)</span>
        <div class="value">16.339</div>
        <div class="verified-badge">Calibrated</div>
      </div>
    </div>

    <section class="research-status">
      <h2>Active Research & Epistemic Audit</h2>
      
      <TruthVerifier client:load />

      <div class="data-card" style={{ marginTop: '2rem' }}>
        <span class="label">L6-FRG Topological Tension</span>
        <p>4.2&sigma; tension against D&uuml;rr et al. (2025). Status: <span style="color: var(--warning)">ACTIVE RESEARCH</span></p>
      </div>
    </section>
	</main>
</Layout>

<style>
  .hero {
    max-width: 800px;
    margin-bottom: 4rem;
  }
  .description {
    font-size: 1.25rem;
    color: var(--text-secondary);
  }
  .research-status {
    margin-top: 4rem;
  }
</style>
